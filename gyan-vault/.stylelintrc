{
  "extends": "stylelint-config-standard",
  "overrides": [
    {
      "files": ["**/*.css"],
      "customSyntax": "postcss-syntax",
      "rules": {
        "at-rule-no-unknown": [
          true,
          {
            "ignoreAtRules": ["tailwind", "apply", "layer", "config"]
          }
        ]
      }
    }
  ]
}
